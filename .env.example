# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real values.

# UniFi controller hostname or IP. Defaults to `unifi.local` if unset.
UDM_HOST=unifi.local

# Optional: provide the API key directly.
# If unset, udm.py falls back to: pass network/unifi/api-key
# UNIFI_API_KEY=your-api-key-here
